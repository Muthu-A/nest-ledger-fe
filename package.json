{
  "name": "NestLedger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "test": "jest",
    "test:unit": "jest --testPathPattern=src/tests/unit",
    "test:integration": "jest --testPathPattern=src/tests/integration",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "start:e2e": "node scripts/start-e2e.cjs",
    "api": "node server.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "security:audit": "npm audit && npm audit fix",
    "security:scan": "eslint --plugin security src/",
    "security:check": "npm run security:audit && npm run security:scan",
    "security:secrets": "git-secrets --scan",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test:security": "npm run security:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.13",
    "apexcharts": "^5.13.0",
    "axios": "^1.16.1",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-apexcharts": "^2.1.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "sanitize-html": "^2.17.5",
    "socket.io-client": "^4.7.2",
    "validator": "^13.15.35",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bcrypt": "^6.0.0",
    "cypress": "^15.17.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.1",
    "express-rate-limit": "^8.5.2",
    "git-secrets": "^0.0.11",
    "globals": "^17.6.0",
    "helmet": "^8.2.0",
    "husky": "^9.1.7",
    "jest": "^25.0.0",
    "lint-staged": "^17.0.7",
    "mongodb-memory-server": "^11.2.0",
    "mongoose": "^7.8.9",
    "supertest": "^7.2.2",
    "ts-jest": "^27.0.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
